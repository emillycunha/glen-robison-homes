---
import '../styles/global.css';
import VIPModal from '../components/VIPModal.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Glen Robison Real Estate | New Braunfels Luxury Real Estate',
  description = 'New Braunfels and Texas Hill Country real estate. Glen Robison is a buyer-focused REALTOR specializing in luxury homes, gated communities, and Hill Country acreage.',
  canonical,
  ogImage,
} = Astro.props;

const siteUrl = 'https://glenrobisonrealestate.com';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const socialImage = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/images/hero-home.png`;

const navLinks = [
  { label: 'Buyers',        href: '/buyers' },
  { label: 'Sell',          href: '/sell' },
  { label: 'Neighborhoods', href: '/neighborhoods' },
  { label: 'Guides',        href: '/living' },
  { label: 'About',         href: '/about' },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['RealEstateAgent', 'LocalBusiness'],
      '@id': `${siteUrl}/#agent`,
      name: 'Glen Robison',
      description: 'New Braunfels, TX REALTOR with Popby Realty, specializing in buyers and luxury homes throughout the Texas Hill Country since 2016.',
      url: siteUrl,
      telephone: '+18307307677',
      email: 'glenrobison@gmail.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '323 Arendes Dr',
        addressLocality: 'New Braunfels',
        addressRegion: 'TX',
        postalCode: '78132',
        addressCountry: 'US',
      },
      memberOf: {
        '@type': 'Organization',
        name: 'Popby Realty',
      },
      areaServed: [
        { '@type': 'City', name: 'New Braunfels', containedInPlace: { '@type': 'State', name: 'Texas' } },
        { '@type': 'City', name: 'Canyon Lake', containedInPlace: { '@type': 'State', name: 'Texas' } },
        { '@type': 'City', name: 'Garden Ridge', containedInPlace: { '@type': 'State', name: 'Texas' } },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'Glen Robison Real Estate',
      description: 'New Braunfels and Hill Country real estate, buyer representation, luxury homes, and relocation guidance.',
      publisher: { '@id': `${siteUrl}/#agent` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Glen Robison Real Estate" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,700;12..96,800&family=Syne:wght@400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <slot name="head" />
  </head>
  <body>

    <!-- HEADER -->
    <header class="sticky top-0 z-50 bg-[var(--color-bg)]/92 backdrop-blur-md border-b border-hair">
      <div class="max-w-7xl mx-auto px-8 h-24 flex items-center justify-between gap-10">

        <a href="/" class="shrink-0 group" aria-label="Glen Robison Real Estate">
          <span class="font-display font-bold text-cream uppercase tracking-[-0.02em] text-[22px] leading-none block group-hover:text-gold-bright transition-colors">Glen Robison</span>
          <span class="font-display text-gold text-[14px] tracking-[0.15em] font-semibold uppercase block">Real Estate</span>
        </a>

        <nav class="hidden lg:flex items-center gap-9">
          {navLinks.map(l => (
            <a
              href={l.href}
              class="font-body text-[13px] text-muted hover:text-gold-bright transition-colors tracking-[0.18em] uppercase font-semibold relative group"
            >
              {l.label}
              <span class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold group-hover:w-full transition-all duration-400"></span>
            </a>
          ))}
        </nav>

        <div class="flex items-center gap-5">
          <a href="tel:+18307307677" class="hidden md:inline-block font-body text-sm text-gold-bright font-semibold tracking-wide">
            (830) 730-7677
          </a>
          <a href="/contact" class="btn-gold hidden sm:inline-flex">
            Contact
          </a>
          <button id="mobile-menu-btn" class="lg:hidden text-gold p-1" aria-label="Toggle menu">
            <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
              <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
            </svg>
          </button>
        </div>

      </div>
    </header>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="fixed inset-0 z-40 hidden lg:hidden">
      <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/80"></div>
      <div class="absolute top-0 right-0 h-full w-80 bg-elevated border-l border-default flex flex-col shadow-2xl">
        <div class="h-20 flex items-center justify-end px-6 border-b border-subtle">
          <button id="mobile-menu-close" class="text-gold p-1" aria-label="Close menu">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="flex flex-col px-8 py-8 gap-1 overflow-y-auto">
          {navLinks.map(l => (
            <a href={l.href} class="font-eyebrow text-sm text-muted hover:text-gold-bright tracking-[0.2em] py-4 border-b border-hair">{l.label}</a>
          ))}
          <a href="/contact" class="btn-gold mt-8 justify-center">Contact</a>
          <a href="tel:+18307307677" class="text-center font-body text-sm text-gold-bright font-semibold tracking-wide mt-4">(830) 730-7677</a>
        </nav>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="bg-elevated border-t border-hair relative">
      <div class="max-w-7xl mx-auto px-8 pt-24 pb-12">

        <!-- Masthead, big and structural -->
        <div class="pb-16 border-b border-hair">
          <p class="eyebrow mb-6">New Braunfels · Texas</p>
          <div class="font-display text-2xl md:text-3xl text-cream font-extrabold tracking-[-0.03em] leading-[1] uppercase">Glen Robison</div>
          <p class="text-muted text-lg max-w-xl mt-8 leading-relaxed">
            Buyer representation and luxury real estate in New Braunfels and the Texas Hill Country.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 py-16">

          <div>
            <p class="eyebrow mb-6">Explore</p>
            <ul class="space-y-3 text-sm">
              <li><a href="/buyers" class="text-muted hover:text-gold-bright">Buyers</a></li>
              <li><a href="/sell" class="text-muted hover:text-gold-bright">Sell</a></li>
              <li><a href="/luxury" class="text-muted hover:text-gold-bright">Luxury Homes</a></li>
              <li><a href="/neighborhoods" class="text-muted hover:text-gold-bright">Neighborhoods</a></li>
              <li><a href="/new-construction" class="text-muted hover:text-gold-bright">New Construction</a></li>
              <li><a href="/about" class="text-muted hover:text-gold-bright">About</a></li>
            </ul>
          </div>

          <div>
            <p class="eyebrow mb-6">Resources</p>
            <ul class="space-y-3 text-sm">
              <li><a href="/buyers-guide" class="text-muted hover:text-gold-bright">Buyer's Guide</a></li>
              <li><a href="/sellers-guide" class="text-muted hover:text-gold-bright">Seller's Guide</a></li>
              <li><a href="/relocation-guide" class="text-muted hover:text-gold-bright">Relocation Guide</a></li>
              <li><a href="/tools/mortgage-calculator" class="text-muted hover:text-gold-bright">Mortgage Calculator</a></li>
              <li><a href="/tools/seller-net-sheet" class="text-muted hover:text-gold-bright">Seller Net Sheet</a></li>
              <li><a href="/blog" class="text-muted hover:text-gold-bright">Blog</a></li>
            </ul>
          </div>

          <div>
            <p class="eyebrow mb-6">Direct</p>
            <ul class="space-y-3 text-sm text-muted">
              <li class="text-cream font-display font-bold uppercase tracking-tight">Glen Robison, <span class="text-gold-bright">REALTOR</span></li>
              <li>323 Arendes Dr</li>
              <li>New Braunfels, TX 78132</li>
              <li><a href="tel:+18307307677" class="text-muted hover:text-gold-bright">(830) 730-7677</a></li>
              <li><a href="mailto:glenrobison@gmail.com" class="text-muted hover:text-gold-bright">glenrobison@gmail.com</a></li>
              <li class="text-dim text-xs">TX License #0676313</li>
            </ul>
          </div>

          <div>
            <img src="/images/popby-logo.avif" alt="Popby Realty" class="h-14 w-auto mb-6" />
            <a href="/contact" class="btn-gold">Contact Glen</a>
            <p class="text-dim text-xs mt-6 leading-relaxed uppercase tracking-wider">Private consultations by appointment. Same-day reply.</p>
          </div>

        </div>

        <div class="pt-10 border-t border-hair">
          <!-- Compliance row: EHO logo + TREC/IABS stacked (left) · social icons (right) -->
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 mb-10">
            <div class="flex items-center gap-4">
              <img
                src="/images/equal-housing.png"
                alt="Equal Housing Opportunity"
                class="h-8 w-auto shrink-0"
                style="filter: brightness(0) invert(1);"
              />
              <div class="flex flex-col gap-1.5 text-[10px] tracking-[0.2em] uppercase font-semibold">
                <a href="/trec-consumer-protection-notice.pdf" target="_blank" rel="noopener" class="text-dim hover:text-gold">TREC Consumer Protection Notice</a>
                <a href="https://www.trec.texas.gov/license-search/?detail_id=1742777" target="_blank" rel="noopener" class="text-dim hover:text-gold">Information About Brokerage Services (IABS)</a>
              </div>
            </div>

            <!-- Social + legal links stacked -->
            <div class="flex flex-col items-center md:items-end gap-4">
              <div class="flex items-center gap-5">
                <a href="https://www.facebook.com/people/Glen-Robison-Realtor/100063651936144/" target="_blank" rel="noopener" class="text-muted hover:text-gold-bright transition-colors" aria-label="Glen Robison on Facebook">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://www.instagram.com/" target="_blank" rel="noopener" class="text-muted hover:text-gold-bright transition-colors" aria-label="Glen Robison on Instagram">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </a>
                <a href="https://www.linkedin.com/in/glen-robison-ii-rpl-realtor-899a9814/" target="_blank" rel="noopener" class="text-muted hover:text-gold-bright transition-colors" aria-label="Glen Robison on LinkedIn">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              </div>
              <div class="text-[10px] text-muted tracking-[0.2em] uppercase font-semibold">
                <a href="/privacy" class="text-muted hover:text-gold-bright">Privacy</a>
                <span class="mx-3 text-dim">·</span>
                <a href="/terms" class="text-muted hover:text-gold-bright">Terms</a>
              </div>
            </div>
          </div>

          <!-- Centered copyright + credit block -->
          <div class="text-center space-y-1 text-[10px] text-muted tracking-[0.25em] uppercase font-semibold">
            <p>© {new Date().getFullYear()} · Glen Robison Real Estate · All Rights Reserved · TX License #0676313</p>
            <p>
              Website designed and developed by <a href="https://whiteboston.com" target="_blank" rel="noopener" class="text-muted hover:text-gold-bright">WhiteBoston</a>
            </p>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const close = document.getElementById('mobile-menu-close');
      const backdrop = document.getElementById('mobile-menu-backdrop');

      function open() { menu?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
      function shut() { menu?.classList.add('hidden'); document.body.style.overflow = ''; }

      btn?.addEventListener('click', open);
      close?.addEventListener('click', shut);
      backdrop?.addEventListener('click', shut);
    </script>

    <VIPModal />
  </body>
</html>
