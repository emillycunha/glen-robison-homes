---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  image?: string;
}
const { eyebrow, title, intro, image } = Astro.props;
const placeholder = image ?? `https://placehold.co/1920x900/0a0a0a/c19a57?font=playfair&text=${encodeURIComponent(title.replace(/\.$/, ''))}`;
---

<section class="relative py-24 md:py-32 border-b border-hair overflow-hidden bg-deep">
  <img
    src={placeholder}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover opacity-65"
  />
  <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-bg)]/70 via-[var(--color-bg)]/55 to-[var(--color-bg)]/85"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-8">
    {eyebrow && <p class="eyebrow mb-6">{eyebrow}</p>}
    <h1 class="mb-8">{title}</h1>
    {intro && <p class="text-lg md:text-xl text-muted leading-[1.6] max-w-2xl">{intro}</p>}
    <slot />
  </div>
</section>
