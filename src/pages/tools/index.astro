---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Real Estate Tools & Calculators | Glen Robison" description="Free real estate calculators for New Braunfels buyers and sellers. Mortgage payment calculator and seller net sheet.">
  <PageHero eyebrow="Tools" title="Calculators & Tools." image="/images/hero-living.png" intro="Free, no-signup calculators for New Braunfels buyers and sellers." />

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href="/tools/mortgage-calculator" class="bg-card border border-subtle hover:border-[var(--color-gold-dim)] p-8 transition-all group">
        <p class="text-gold text-[10px] font-semibold uppercase tracking-[0.2em] mb-3">For Buyers</p>
        <h3 class="mb-3 group-hover:text-gold-bright transition-colors">Mortgage Calculator</h3>
        <p class="text-muted text-sm leading-relaxed">Estimate your monthly mortgage payment including principal, interest, taxes, and insurance.</p>
      </a>
      <a href="/tools/seller-net-sheet" class="bg-card border border-subtle hover:border-[var(--color-gold-dim)] p-8 transition-all group">
        <p class="text-gold text-[10px] font-semibold uppercase tracking-[0.2em] mb-3">For Sellers</p>
        <h3 class="mb-3 group-hover:text-gold-bright transition-colors">Seller Net Sheet</h3>
        <p class="text-muted text-sm leading-relaxed">Estimate what you'll walk away with after commissions, closing costs, and payoffs.</p>
      </a>
    </div>
  </section>
</Layout>
