---
import Layout from '../layouts/Layout.astro';
import CTABand from '../components/CTABand.astro';
import { neighborhoods } from '../data/neighborhoods.js';
import { testimonials } from '../data/testimonials.js';
import { blogPosts } from '../data/blog-posts.js';

const latestPosts = [...blogPosts].sort((a, b) => (a.pubDate < b.pubDate ? 1 : -1)).slice(0, 4);
const fmtDate = (iso) => new Date(iso + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

const luxuryNeighborhoods = [...neighborhoods.slice(0, 5), neighborhoods.find(n => n.slug === 'john-newcombe-estate')];
const featuredTestimonials = testimonials.slice(0, 4);
---



<Layout
  title="Glen Robison | New Braunfels TX REALTOR"
  description="New Braunfels REALTOR Glen Robison. 10 years local, 160+ sales. Luxury homes, buyer representation, and Hill Country relocation."
>
  <!-- HERO, architectural, confident, not editorial -->
  <section class="relative min-h-[88vh] flex items-start overflow-hidden bg-deep">
    <img
      src="/images/hero-home.webp"
      alt="Luxury Texas Hill Country estate at golden hour"
      width="1376"
      height="768"
      fetchpriority="high"
      class="absolute inset-0 w-full h-full object-cover opacity-25"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg)] via-[var(--color-bg)]/55 to-[var(--color-bg)]/15"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-8 py-8 md:py-20 w-full">
      <div class="flex items-end justify-between flex-wrap gap-10">
        <div class="max-w-4xl">
          <p class="eyebrow mb-8 rise-1">New Braunfels, Texas</p>

          <h1 class="mb-8 rise-2" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 0.92;">
            Luxury<br/>
            <span class="text-gold-bright">Hill Country</span><br/>
            Real Estate.
          </h1>

          <p class="font-body text-lg md:text-xl text-muted max-w-2xl mb-10 leading-[1.55] rise-3">
            Real estate help in the Texas Hill Country. Honest answers, local expertise, and a REALTOR who actually picks up the phone.
          </p>

          <div class="flex flex-wrap gap-4 rise-4">
            <a href="/search" class="btn-gold">Search Homes</a>
            <a href="/contact" class="btn-outline">Schedule a Call</a>
          </div>
        </div>

        <!-- Vertical metadata -->
        <div class="hidden lg:flex flex-col gap-8 items-end text-right rise-5">
          <div>
            <p class="eyebrow text-gold mb-3">Specialty</p>
            <p class="font-display font-bold uppercase text-cream text-xl leading-[1.2]">Luxury<br/>Buyer Rep</p>
          </div>
          <div class="hair-rule w-32"></div>
          <div>
            <p class="eyebrow text-gold mb-3">Market</p>
            <p class="font-display font-bold uppercase text-cream text-xl leading-[1.2]">New Braunfels<br/>Hill Country</p>
          </div>
          <div class="hair-rule w-32"></div>
          <div>
            <p class="eyebrow text-gold mb-3">Call or Text</p>
            <a href="tel:+18307307677" class="font-display font-bold text-gold-bright text-xl leading-[1.2] hover:text-cream transition-colors block">
              (830)<br/>730-7677
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom metadata strip, marquee on mobile -->
    <div class="absolute bottom-10 md:bottom-0 left-0 right-0 border-t border-hair bg-[var(--color-bg)]/60 backdrop-blur-sm overflow-hidden">
      <div class="hidden md:flex max-w-7xl mx-auto px-8 py-5 justify-between items-center gap-6 text-xs uppercase tracking-[0.2em] text-dim font-semibold">
        <span>Luxury Homes</span>
        <span>Gated Communities</span>
        <span>Hill Country Acreage</span>
        <span>Riverfront</span>
        <span>New Construction</span>
      </div>
      <div class="md:hidden py-5">
        <div class="marquee-track text-xs uppercase tracking-[0.2em] text-dim font-semibold whitespace-nowrap">
          <span class="inline-block px-6">Luxury Homes</span>
          <span class="inline-block px-6">Gated Communities</span>
          <span class="inline-block px-6">Hill Country Acreage</span>
          <span class="inline-block px-6">Riverfront</span>
          <span class="inline-block px-6">New Construction</span>
          <span class="inline-block px-6">Luxury Homes</span>
          <span class="inline-block px-6">Gated Communities</span>
          <span class="inline-block px-6">Hill Country Acreage</span>
          <span class="inline-block px-6">Riverfront</span>
          <span class="inline-block px-6">New Construction</span>
        </div>
      </div>
    </div>
  </section>

  <!-- STATEMENT BLOCK, light section -->
  <section class="light-section py-28 md:py-36 border-t border-[#d8d3cb]">
    <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-[380px_1fr] gap-12 md:gap-16 items-center">
      <div class="relative order-2 md:order-1">
        <img
          src="/images/glen-approach.webp"
          alt="Real estate agent approaching a luxury Hill Country home"
          class="w-full aspect-[4/5] object-cover border border-[#d8d3cb]"
        />
        <div class="absolute -bottom-4 -right-4 bg-[var(--color-bg)] border border-hair py-3 px-5">
          <p class="eyebrow text-gold-bright">Buyers & Sellers</p>
        </div>
      </div>
      <div class="order-1 md:order-2">
        <p class="eyebrow mb-6">The Approach</p>
        <h2 class="mb-8">
          Your home is the biggest deal you'll ever make. <span class="text-[#999]">Glen treats it that way.</span>
        </h2>
        <p class="text-base md:text-lg leading-[1.7] mb-5">
          Ten years in New Braunfels. 160+ closed sales. Glen knows the neighborhoods, the builders, the prices, and the streets that hold their value. More importantly, he tells you the truth about what he sees.
        </p>
        <p class="text-base md:text-lg leading-[1.7]">
          Buyers get a REALTOR who knows where to look and what to walk away from. Sellers get someone who prices it right the first time and brings real buyers to the door.
        </p>
      </div>
    </div>
  </section>

  <!-- STATS BAND, credibility numbers -->
  <section class="py-20 border-t border-hair bg-elevated">
    <div class="max-w-7xl mx-auto px-8">
      <div class="text-center mb-14">
        <h2>A decade in <span class="text-gold-bright">New Braunfels.</span></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-12 gap-y-14 items-start">
        <div class="text-center">
          <div class="font-display font-extrabold text-gold-bright text-6xl md:text-7xl leading-none tracking-[-0.04em]">10</div>
          <p class="eyebrow text-dim mt-4">Years Experience</p>
        </div>
        <div class="text-center">
          <div class="font-display font-extrabold text-gold-bright text-6xl md:text-7xl leading-none tracking-[-0.04em]">160+</div>
          <p class="eyebrow text-dim mt-4">Total Sales</p>
        </div>
        <div class="text-center">
          <div class="font-display font-extrabold text-gold-bright text-6xl md:text-7xl leading-none tracking-[-0.04em]"><span class="text-4xl md:text-5xl align-middle mr-2">★</span>5.0</div>
          <p class="eyebrow text-dim mt-4">65 Team Reviews · Zillow</p>
        </div>
      </div>
      <div class="mt-14 text-center text-dim text-xs uppercase tracking-[0.2em]">
        Top Agent on Zillow · Price range $183K – $1.8M · 14 sales in the last 12 months · Verified on <a href="https://www.zillow.com/profile/Glen%20Robison#reviews" target="_blank" rel="noopener" class="text-gold hover:text-gold-bright">Zillow</a>
      </div>
    </div>
  </section>

  <!-- VALUE PROPS, light section -->
  <section class="light-section py-32 border-t border-[#d8d3cb]">
    <div class="max-w-7xl mx-auto px-8">
      <div class="mb-16 max-w-3xl">
        <p class="eyebrow mb-5">What You Get</p>
        <h2>
          Three things Glen brings <span class="text-gold">to every deal.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-10 gap-y-14">
        <div>
          <div class="flex items-baseline gap-4 mb-5">
            <span class="font-display font-extrabold text-4xl text-gold">01</span>
            <div class="h-px flex-1 bg-[#d8d3cb]"></div>
          </div>
          <h3 class="mb-4">Honest Representation</h3>
          <p class="leading-[1.7] text-base">Glen works for you, not the deal. He'll tell you when a home is overpriced, when an inspection report is a dealbreaker, and when to walk away. The good agents say no more than yes.</p>
        </div>
        <div>
          <div class="flex items-baseline gap-4 mb-5">
            <span class="font-display font-extrabold text-4xl text-gold">02</span>
            <div class="h-px flex-1 bg-[#d8d3cb]"></div>
          </div>
          <h3 class="mb-4">Luxury Specialist</h3>
          <p class="leading-[1.7] text-base">Gated communities. Ridgetop homes. Riverfront acreage. Country-club streets. Glen knows the top of the New Braunfels market and the homes that never hit the public listings.</p>
        </div>
        <div>
          <div class="flex items-baseline gap-4 mb-5">
            <span class="font-display font-extrabold text-4xl text-gold">03</span>
            <div class="h-px flex-1 bg-[#d8d3cb]"></div>
          </div>
          <h3 class="mb-4">Hill Country Local</h3>
          <p class="leading-[1.7] text-base">Vintage Oaks. Canyon Lake. Garden Ridge. Riverforest. Glen has walked every one. That's local detail an out-of-town agent can't fake.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LUXURY NEIGHBORHOODS, architectural index -->
  <section class="py-32 bg-elevated border-y border-hair">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-8">
        <div>
          <p class="eyebrow mb-5">The Short List</p>
          <h2 class="max-w-2xl">
            Addresses <span class="text-gold-bright">worth knowing.</span>
          </h2>
        </div>
        <p class="text-muted text-base max-w-sm leading-relaxed">
          Six neighborhoods that anchor the New Braunfels luxury market. Each one is different. Each one is worth knowing.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {luxuryNeighborhoods.map((n, i) => (
          <a href={`/neighborhoods/${n.slug}`} class="group block">
            <div class="relative overflow-hidden aspect-[4/5] bg-card">
              <img
                src={n.image ?? `https://placehold.co/800x1000/161616/c19a57?font=playfair&text=${encodeURIComponent(n.name)}`}
                alt={n.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-all duration-[800ms]"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>

              <!-- Corner number -->
              <div class="absolute top-6 left-6 font-display font-extrabold text-gold-bright text-2xl">{String(i + 1).padStart(2, '0')}</div>

              <!-- Bottom metadata -->
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <p class="eyebrow text-gold-bright mb-2 text-[10px]">{n.segment.replace(' (anchor)', '')}</p>
                <h3 class="text-cream group-hover:text-gold-bright transition-colors">{n.name}</h3>
              </div>
            </div>
            <div class="flex items-center justify-between pt-4">
              <p class="text-muted text-sm font-medium">{n.priceRange}</p>
              <span class="eyebrow text-[10px] text-gold group-hover:text-gold-bright">View →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-16 text-center">
        <a href="/neighborhoods" class="btn-outline">More Neighborhoods</a>
      </div>
    </div>
  </section>

  <!-- ABOUT BLOCK, light section -->
  <section class="light-section py-32 border-t border-[#d8d3cb]">
    <div class="max-w-6xl mx-auto px-8 grid grid-cols-1 md:grid-cols-[400px_1fr] gap-16 items-start">
      <div class="relative">
        <img
          src="/images/glen-headshot-home.webp"
          alt="Glen Robison, REALTOR with Popby Realty in New Braunfels, TX"
          class="w-full aspect-[4/5] object-cover"
        />
      </div>
      <div class="pt-4">
        <p class="eyebrow mb-5">Meet Glen</p>
        <h2 class="mb-8">
          A REALTOR <span class="text-gold">who answers.</span>
        </h2>
        <p class="text-base md:text-lg leading-[1.7] mb-5">
          Glen is a trusted REALTOR with Popby Realty in New Braunfels. With 10 years in real estate and over 20 years negotiating with landowners and attorneys as an oil and gas landman, he brings contract discipline and strategic guidance to every deal.
        </p>
        <p class="text-base md:text-lg leading-[1.7] mb-10">
          While Glen has deep experience in luxury real estate, he is honored to work with anyone looking to buy or sell: first-time buyers, Veterans, relocating families, and clients at every price point. Outside of work he's a husband, a dad to three daughters, and active in his church and community.
        </p>
        <a href="/about" class="btn-outline">About Glen Robison</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="light-section py-32 border-t border-[#d8d3cb]">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-8">
        <div>
          <p class="eyebrow mb-5">What Clients Say</p>
          <h2 class="max-w-2xl">
            In their <span class="text-gold">own words.</span>
          </h2>
        </div>
        <p class="text-base max-w-sm leading-relaxed">
          Real reviews from buyers and sellers across New Braunfels, Canyon Lake, and the Hill Country.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featuredTestimonials.map((t, i) => (
          <div class="arch-card p-10 flex flex-col">
            <!-- Decorative quote mark -->
            <div class="font-display text-gold text-6xl leading-none mb-4 opacity-70">"</div>
            <p class="text-cream text-base md:text-lg leading-[1.65] mb-8 flex-1">{t.quote}</p>
            <div class="h-px w-12 bg-gold-deep mb-5"></div>
            <div class="flex items-baseline justify-between gap-4">
              <div>
                <p class="text-cream font-semibold text-sm">{t.author}</p>
                <p class="eyebrow text-[10px] text-dim mt-1">{t.context}</p>
              </div>
              <div class="text-gold text-sm tracking-wider">★★★★★</div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center flex flex-wrap gap-4 justify-center">
        <a href="/testimonials" class="btn-gold">Read More Reviews</a>
        <a href="https://www.zillow.com/profile/Glen%20Robison#reviews" target="_blank" rel="noopener" class="btn-outline">Verified on Zillow →</a>
      </div>
    </div>
  </section>

  <!-- GUIDES -->
  <section class="py-32 bg-elevated border-y border-hair">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-8">
        <div>
          <p class="eyebrow mb-5">Before You Call</p>
          <h2 class="max-w-2xl">
            Start with <span class="text-gold-bright">the guides.</span>
          </h2>
        </div>
        <p class="text-muted text-base max-w-sm leading-relaxed">
          Free guides, a mortgage calculator, and the real story on moving here. Enter your email once and the full guides open.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/buyers-guide" class="arch-card p-8 group">
          <p class="eyebrow mb-5">Unlock Free</p>
          <h3 class="mb-4 group-hover:text-gold-bright transition-colors">Buyer's Guide</h3>
          <div class="h-px w-12 bg-gold-deep my-5"></div>
          <p class="text-muted leading-relaxed mb-8 text-base">Financing, inspections, contracts, closing. Unlock the full guide with one email.</p>
          <span class="eyebrow text-[10px] text-gold group-hover:text-gold-bright">Unlock →</span>
        </a>
        <a href="/tools/mortgage-calculator" class="arch-card p-8 group">
          <p class="eyebrow mb-5">Calculator</p>
          <h3 class="mb-4 group-hover:text-gold-bright transition-colors">Mortgage Payment</h3>
          <div class="h-px w-12 bg-gold-deep my-5"></div>
          <p class="text-muted leading-relaxed mb-8 text-base">Estimate your monthly payment with principal, interest, taxes, and insurance.</p>
          <span class="eyebrow text-[10px] text-gold group-hover:text-gold-bright">Run Numbers →</span>
        </a>
        <a href="/living/why-move-to-new-braunfels" class="arch-card p-8 group">
          <p class="eyebrow mb-5">Relocation</p>
          <h3 class="mb-4 group-hover:text-gold-bright transition-colors">Why New Braunfels</h3>
          <div class="h-px w-12 bg-gold-deep my-5"></div>
          <p class="text-muted leading-relaxed mb-8 text-base">Growth, taxes, schools, and why so many families are moving here.</p>
          <span class="eyebrow text-[10px] text-gold group-hover:text-gold-bright">Read →</span>
        </a>
      </div>

      <div class="mt-16 text-center">
        <a href="/living" class="btn-outline">Full Resource Library →</a>
      </div>
    </div>
  </section>

  <!-- LATEST FROM THE BLOG -->
  <section class="py-32 bg-elevated">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-8">
        <div>
          <p class="eyebrow mb-5">The Blog</p>
          <h2>Latest from <span class="text-gold-bright">Glen.</span></h2>
        </div>
        <a href="/blog" class="btn-outline">All Posts</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {latestPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="group block">
            <div class="relative overflow-hidden aspect-[4/3] mb-4">
              <img
                src={post.image || '/images/hero-blog.webp'}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            </div>
            <p class="text-dim text-[11px] uppercase tracking-[0.12em] font-semibold mb-2">{post.category} · {fmtDate(post.pubDate)}</p>
            <h3 class="text-[15px] leading-[1.3] mb-2 group-hover:text-gold-bright transition-colors">{post.title}</h3>
            <p class="text-muted text-sm leading-[1.55] line-clamp-2">{post.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="py-32 relative overflow-hidden border-t border-hair bg-deep">
    <div class="absolute inset-0 opacity-[0.04]" style="background: radial-gradient(ellipse at center, var(--color-gold) 0%, transparent 60%);"></div>
    <div class="relative max-w-4xl mx-auto px-8 text-center">
      <p class="eyebrow mb-6">Last Thing</p>
      <h2 class="mb-8">
        Let's <span class="text-gold-bright">talk.</span>
      </h2>
      <p class="text-lg md:text-xl text-muted leading-[1.6] mb-10 max-w-2xl mx-auto">
        A real phone call about what you want, what the market is doing, and whether Glen is the right fit for you.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact" class="btn-gold">Schedule a Call</a>
        <a href="/luxury" class="btn-outline">Browse Luxury Homes</a>
      </div>
    </div>
  </section>
</Layout>
