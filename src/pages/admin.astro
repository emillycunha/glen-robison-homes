---
// Admin SPA - standalone page, no Layout wrapper
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin | Glen Robison Real Estate</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #08090a; --surface: #111214; --surface2: #181a1d; --surface3: #1e2024;
      --text: #eceae6; --muted: #c4bfb7; --dim: #7a756d;
      --gold: #c19a57; --gold-b: #dbb978; --gold-d: #8a6d3a; --gold-glow: rgba(193,154,87,0.08);
      --border: #232527; --border-light: #2e3033;
      --red: #e8634a; --green: #4aba7a; --blue: #5b9cf5;
      --radius: 10px; --radius-sm: 6px;
    }
    body { background: var(--bg); color: var(--text); font-family: 'Manrope', system-ui, sans-serif; font-size: 14px; line-height: 1.55; -webkit-font-smoothing: antialiased; }
    a { color: var(--gold); text-decoration: none; }

    /* ── LOGIN ── */
    #login {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      background: radial-gradient(ellipse at 50% 30%, rgba(193,154,87,0.04) 0%, transparent 70%);
    }
    .login-card {
      width: 100%; max-width: 380px; padding: 48px 36px; background: var(--surface);
      border: 1px solid var(--border); border-radius: var(--radius);
    }
    .login-card .brand { font-family: 'Manrope', system-ui, sans-serif; font-weight: 800; font-size: 18px; text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 6px; }
    .login-card .brand span { color: var(--gold); }
    .login-card .sub { font-size: 13px; color: var(--dim); margin-bottom: 32px; }
    .login-card label { display: block; font-size: 11px; font-weight: 700; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
    .login-card input {
      width: 100%; padding: 12px 14px; background: var(--bg); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text); font-size: 14px; outline: none;
      transition: border-color 0.2s;
    }
    .login-card input:focus { border-color: var(--gold); }
    .login-card .field { margin-bottom: 16px; }
    .login-card button {
      width: 100%; padding: 14px; margin-top: 8px; background: var(--gold); color: #0a0a0a;
      font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: 0.12em;
      border: none; border-radius: var(--radius-sm); cursor: pointer; transition: background 0.2s;
    }
    .login-card button:hover { background: var(--gold-b); }
    .err { color: var(--red); font-size: 12px; margin-top: 10px; min-height: 18px; }

    /* ── SHELL ── */
    #app { display: none; min-height: 100vh; }
    .topbar {
      background: var(--surface); border-bottom: 1px solid var(--border);
      padding: 0 28px; height: 60px; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 50;
    }
    .topbar .brand { font-family: 'Manrope', system-ui, sans-serif; font-weight: 700; font-size: 15px; text-transform: uppercase; letter-spacing: -0.01em; }
    .topbar .brand span { color: var(--gold); }
    .topbar .right { display: flex; align-items: center; gap: 20px; }
    .topbar .site-link { font-size: 12px; color: var(--dim); }
    .topbar .site-link:hover { color: var(--gold); }
    .topbar .logout {
      font-size: 11px; color: var(--dim); cursor: pointer; text-transform: uppercase;
      letter-spacing: 0.08em; font-weight: 600; padding: 6px 12px; border: 1px solid var(--border);
      border-radius: var(--radius-sm); transition: all 0.2s;
    }
    .topbar .logout:hover { color: var(--text); border-color: var(--border-light); }

    .tabs {
      background: var(--surface); border-bottom: 1px solid var(--border);
      padding: 0 28px; display: flex; gap: 4px;
    }
    .tab {
      padding: 14px 20px; font-size: 12px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--dim); cursor: pointer;
      border-bottom: 2px solid transparent; transition: all 0.2s; position: relative;
    }
    .tab:hover { color: var(--muted); }
    .tab.active { color: var(--gold); border-bottom-color: var(--gold); }

    /* Mobile burger menu */
    .burger-btn {
      display: none; background: none; border: 1px solid var(--border); border-radius: var(--radius-sm);
      color: var(--muted); cursor: pointer; padding: 6px 10px; transition: all 0.2s;
    }
    .burger-btn:hover { color: var(--gold); border-color: var(--gold-d); }
    .burger-btn svg { width: 20px; height: 20px; }
    .mobile-nav {
      display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 100;
      background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
    }
    .mobile-nav.open { display: flex; align-items: flex-start; justify-content: center; padding-top: 80px; }
    .mobile-nav-inner {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 8px; width: calc(100% - 32px); max-width: 320px;
    }
    .mobile-nav-item {
      display: block; width: 100%; text-align: left; padding: 14px 18px; font-size: 13px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--dim); background: none; border: none; cursor: pointer;
      border-radius: var(--radius-sm); transition: all 0.15s;
    }
    .mobile-nav-item:hover { color: var(--text); background: var(--surface2); }
    .mobile-nav-item.active { color: var(--gold); background: var(--gold-glow); }

    .settings-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .settings-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

    @media (max-width: 640px) {
      .tabs { display: none; }
      .burger-btn { display: flex; }
      .topbar { padding: 0 16px; }
      .content { padding: 20px 16px; }
      .lead-card .lead-top { flex-direction: column; gap: 10px; }
      .source-card { padding: 16px; }
      .source-card .mini-stats { grid-template-columns: 1fr 1fr; }
      .source-card .mini-stat .mini-num { font-size: 22px; }
      .settings-grid-2 { grid-template-columns: 1fr; }
      .settings-grid-3 { grid-template-columns: 1fr; }
    }

    .content { max-width: 1100px; margin: 0 auto; padding: 32px 28px; }

    /* ── STAT CARDS ── */
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 36px; }
    .stat-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 28px 24px; position: relative; overflow: hidden;
    }
    .stat-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, var(--gold), var(--gold-b));
    }
    .stat-card .num {
      font-family: 'Manrope', system-ui, sans-serif; font-size: 40px; font-weight: 800;
      color: var(--text); line-height: 1; letter-spacing: -0.03em;
    }
    .stat-card .label {
      font-size: 11px; color: var(--dim); text-transform: uppercase;
      letter-spacing: 0.12em; margin-top: 10px; font-weight: 600;
    }

    /* ── TABLES ── */
    .section-title {
      font-size: 12px; font-weight: 700; color: var(--muted); text-transform: uppercase;
      letter-spacing: 0.1em; margin-bottom: 14px; margin-top: 36px;
    }
    .section-title:first-child { margin-top: 0; }
    .table-wrap {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); overflow: hidden;
    }
    .table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .table th {
      text-align: left; padding: 12px 16px; font-size: 11px; font-weight: 700;
      color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em;
      background: var(--surface2); border-bottom: 1px solid var(--border);
    }
    .table td { padding: 11px 16px; border-bottom: 1px solid var(--border); color: var(--muted); }
    .table tr:last-child td { border-bottom: none; }
    .table tr:hover td { background: var(--gold-glow); }
    .table .page-path { color: var(--text); font-weight: 500; }
    .table .views-num { color: var(--gold-b); font-weight: 700; font-family: 'Manrope', system-ui, sans-serif; }

    /* ── CARDS (leads, drafts) ── */
    .card {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 22px 24px; margin-bottom: 12px; transition: border-color 0.2s;
    }
    .card:hover { border-color: var(--border-light); }
    .card-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
    .card h3 { font-size: 15px; font-weight: 700; margin-bottom: 4px; color: var(--text); }
    .card .meta { font-size: 12px; color: var(--dim); font-weight: 500; }
    .card .notes { font-size: 13px; color: var(--muted); margin-top: 10px; padding: 10px 14px; background: var(--surface2); border-radius: var(--radius-sm); border-left: 2px solid var(--gold-d); }

    /* ── BADGES ── */
    .badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 12px; font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; border-radius: 20px;
    }
    .badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; }
    .badge-new { color: var(--gold-b); background: rgba(193,154,87,0.12); }
    .badge-new::before { background: var(--gold); }
    .badge-contacted { color: var(--blue); background: rgba(91,156,245,0.1); }
    .badge-contacted::before { background: var(--blue); }
    .badge-qualified { color: var(--green); background: rgba(74,186,122,0.1); }
    .badge-qualified::before { background: var(--green); }
    .badge-closed { color: var(--muted); background: rgba(154,149,142,0.1); }
    .badge-closed::before { background: var(--muted); }
    .badge-draft { color: var(--gold); background: rgba(193,154,87,0.1); }
    .badge-draft::before { background: var(--gold); }
    .badge-approved { color: var(--green); background: rgba(74,186,122,0.1); }
    .badge-approved::before { background: var(--green); }
    .badge-published { color: var(--blue); background: rgba(91,156,245,0.1); }
    .badge-published::before { background: var(--blue); }
    .badge-trashed { color: var(--dim); background: rgba(92,88,80,0.15); }
    .badge-trashed::before { background: var(--dim); }

    /* ── BUTTONS ── */
    .btn {
      padding: 7px 14px; font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.06em; border: 1px solid var(--border); color: var(--muted);
      background: transparent; cursor: pointer; border-radius: var(--radius-sm); transition: all 0.2s;
    }
    .btn:hover { border-color: var(--gold-d); color: var(--gold); }
    .btn-gold { background: var(--gold); color: #0a0a0a; border-color: var(--gold); }
    .btn-gold:hover { background: var(--gold-b); border-color: var(--gold-b); }
    .btn-danger { color: var(--red); border-color: rgba(232,99,74,0.3); }
    .btn-danger:hover { border-color: var(--red); }
    .actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px; }

    /* ── EDITOR ── */
    .editor-field { margin-bottom: 16px; }
    .editor-field label {
      display: block; font-size: 11px; font-weight: 700; color: var(--dim);
      text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;
    }
    .editor-field input, .editor-field textarea {
      width: 100%; padding: 12px 14px; background: var(--bg); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text); font-size: 14px; outline: none; transition: border 0.2s;
    }
    .editor-field textarea { min-height: 360px; font-family: 'Manrope', monospace; line-height: 1.7; resize: vertical; }

    /* ── DRAFT VIEW ── */
    .draft-view { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .draft-view .draft-header { padding: 24px 28px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
    .draft-view .draft-header h2 { font-size: 20px; font-weight: 800; margin-bottom: 6px; }
    .draft-view .draft-header .meta { font-size: 12px; color: var(--dim); }
    .draft-view .draft-body { padding: 28px; }
    .draft-view .draft-excerpt { font-size: 15px; color: var(--muted); line-height: 1.7; padding-bottom: 20px; margin-bottom: 20px; border-bottom: 1px solid var(--border); font-style: italic; }
    .draft-view .draft-content { font-size: 14px; color: var(--muted); line-height: 1.8; white-space: pre-wrap; }
    .draft-view .draft-footer { padding: 16px 28px; border-top: 1px solid var(--border); display: flex; gap: 8px; }
    .editor-field input:focus, .editor-field textarea:focus { border-color: var(--gold); }

    /* ── SUB TABS ── */
    .sub-tabs { display: flex; gap: 6px; margin-bottom: 20px; }
    .sub-tab {
      padding: 7px 16px; font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--dim); background: var(--surface);
      border: 1px solid var(--border); border-radius: 20px; cursor: pointer; transition: all 0.2s;
    }
    .sub-tab:hover { color: var(--muted); border-color: var(--border-light); }
    .sub-tab.active { color: var(--gold); border-color: var(--gold-d); background: var(--gold-glow); }

    /* ── LEAD CARDS ── */
    .lead-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 0; margin-bottom: 12px; overflow: hidden; transition: border-color 0.2s;
    }
    .lead-card:hover { border-color: var(--border-light); }
    .lead-card .lead-top { padding: 20px 24px; display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
    .lead-card .lead-name { font-size: 16px; font-weight: 700; margin-bottom: 2px; }
    .lead-card .lead-email { font-size: 13px; color: var(--gold); }
    .lead-card .lead-meta { display: flex; gap: 16px; margin-top: 8px; font-size: 12px; color: var(--dim); }
    .lead-card .lead-source {
      display: inline-flex; align-items: center; gap: 4px; padding: 2px 10px;
      font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      background: var(--surface2); border-radius: 4px; color: var(--muted);
    }
    .lead-card .lead-notes { padding: 0 24px 16px; }
    .lead-card .lead-notes p {
      font-size: 13px; color: var(--muted); padding: 10px 14px;
      background: var(--surface2); border-radius: var(--radius-sm); border-left: 2px solid var(--gold-d);
      white-space: pre-line;
    }
    .lead-card .lead-actions { padding: 12px 24px; border-top: 1px solid var(--border); display: flex; gap: 8px; flex-wrap: wrap; }

    .pagination { display: flex; align-items: center; justify-content: center; gap: 6px; margin-top: 24px; }
    .page-btn {
      width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; color: var(--dim); background: var(--surface);
      border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; transition: all 0.2s;
    }
    .page-btn:hover { color: var(--text); border-color: var(--border-light); }
    .page-btn.active { color: var(--gold); border-color: var(--gold-d); background: var(--gold-glow); }
    .page-btn.disabled { opacity: 0.3; pointer-events: none; }

    .count-bar { font-size: 12px; color: var(--dim); font-weight: 600; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .count-bar .pill { background: var(--surface2); padding: 3px 10px; border-radius: 12px; font-size: 11px; color: var(--gold); font-weight: 700; }
    .empty { text-align: center; padding: 80px 20px; color: var(--dim); font-size: 14px; }
    .loading { text-align: center; padding: 60px; color: var(--dim); font-size: 13px; letter-spacing: 0.05em; }

    /* ── DATA SOURCES ── */
    .date-filter {
      display: flex; align-items: center; gap: 8px; margin-bottom: 20px;
    }
    .date-filter .filter-label { font-size: 11px; color: var(--dim); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
    .date-filter select {
      padding: 7px 12px; background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text); font-size: 12px; font-weight: 600;
      outline: none; cursor: pointer;
    }
    .date-filter select:focus { border-color: var(--gold); }
    .source-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 24px; margin-bottom: 16px; position: relative; overflow: hidden;
    }
    .source-card .source-header {
      display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;
      padding-bottom: 14px; border-bottom: 1px solid var(--border);
    }
    .source-card .source-name { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }
    .source-card .source-sub { font-size: 11px; color: var(--dim); }
    .source-card .mini-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 16px; }
    .source-card .mini-stat .mini-num { font-size: 30px; font-weight: 800; color: var(--text); line-height: 1; }
    .source-card .mini-stat .mini-label { font-size: 10px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 4px; font-weight: 600; }

    .toggle-btn {
      display: inline-flex; align-items: center; gap: 6px; margin-top: 8px; padding: 6px 14px;
      font-size: 11px; font-weight: 600; color: var(--dim); background: var(--surface2);
      border: 1px solid var(--border); border-radius: 20px; cursor: pointer; transition: all 0.2s;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .toggle-btn:hover { color: var(--gold); border-color: var(--gold-d); }
    .hidden-rows { display: none; }
    .hidden-rows.show { display: table-row-group; }
  </style>
</head>
<body>

  <!-- LOGIN -->
  <div id="login">
    <div class="login-card">
      <div class="brand">Glen Robison <span>Admin</span></div>
      <div class="sub">Sign in to manage your site</div>
      <div id="login-form">
        <div class="field">
          <label for="login-email">Email</label>
          <input type="email" id="login-email" placeholder="you@example.com" />
        </div>
        <div class="field">
          <label for="login-pass">Password</label>
          <input type="password" id="login-pass" placeholder="Enter password" />
        </div>
        <button id="login-btn">Sign In</button>
        <div class="err" id="login-err"></div>
      </div>
      <div id="register-form" style="display:none">
        <div class="field"><label>Name</label><input type="text" id="reg-name" placeholder="Full name" /></div>
        <div class="field"><label>Email</label><input type="email" id="reg-email" placeholder="you@example.com" /></div>
        <div class="field"><label>Password</label><input type="password" id="reg-pass" placeholder="Choose a password" /></div>
        <button id="register-btn">Create Account</button>
        <div class="err" id="register-err"></div>
      </div>
    </div>
  </div>

  <!-- APP -->
  <div id="app">
    <div class="topbar">
      <div class="brand">Glen Robison <span>Admin</span></div>
      <div class="right">
        <a href="/" class="site-link" target="_blank">View Site</a>
        <span class="logout" id="logout-btn">Sign Out</span>
        <button class="burger-btn" id="burger-btn" aria-label="Menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
      </div>
    </div>

    <div class="tabs">
      <div class="tab active" data-tab="stats">Stats</div>
      <div class="tab" data-tab="leads">Leads</div>
      <div class="tab" data-tab="blog">Blog Drafts</div>
      <div class="tab" data-tab="settings">Blog Settings</div>
    </div>

    <!-- Mobile nav overlay -->
    <div class="mobile-nav" id="mobile-nav">
      <div class="mobile-nav-inner">
        <button class="mobile-nav-item active" data-tab="stats">Stats</button>
        <button class="mobile-nav-item" data-tab="leads">Leads</button>
        <button class="mobile-nav-item" data-tab="blog">Blog Drafts</button>
        <button class="mobile-nav-item" data-tab="settings">Blog Settings</button>
      </div>
    </div>

    <div class="content">
      <div id="view-stats"></div>
      <div id="view-leads" style="display:none"></div>
      <div id="view-blog" style="display:none"></div>
      <div id="view-settings" style="display:none"></div>
    </div>
  </div>

  <script is:inline>
    let TOKEN = localStorage.getItem('admin_token') || '';
    const API = '/api';
    const isLocal = location.hostname === 'localhost' || location.hostname === '127.0.0.1';

    function showApp() {
      document.getElementById('login').style.display = 'none';
      document.getElementById('app').style.display = 'block';
      loadStats();
    }

    function doLogin() {
      const email = document.getElementById('login-email').value.trim();
      const pass = document.getElementById('login-pass').value;
      if (!email || !pass) return;
      if (isLocal) { TOKEN = 'local-dev'; localStorage.setItem('admin_token', TOKEN); showApp(); return; }
      fetch(`${API}/auth/login`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, password: pass }) })
        .then(r => r.json()).then(data => {
          if (data.error) { document.getElementById('login-err').textContent = data.error; return; }
          TOKEN = data.token; localStorage.setItem('admin_token', TOKEN); showApp();
        }).catch(() => { document.getElementById('login-err').textContent = 'Connection error'; });
    }

    function doRegister() {
      const name = document.getElementById('reg-name')?.value.trim();
      const email = document.getElementById('reg-email')?.value.trim();
      const pass = document.getElementById('reg-pass')?.value;
      if (!email || !pass) return;
      fetch(`${API}/auth/register`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, email, password: pass }) })
