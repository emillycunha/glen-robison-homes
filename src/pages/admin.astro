        else if (k === 'innerHTML') el.innerHTML = v;
        else if (k === 'style') Object.assign(el.style, v);
        else el.setAttribute(k, v);
      });
      children.flat().forEach(c => { if (typeof c === 'string') el.appendChild(document.createTextNode(c)); else if (c) el.appendChild(c); });
