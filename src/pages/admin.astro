    function buildTable(rows, col1, col2, col1Key, col2Key, limit = 10) {
      const id = 'toggle-' + (++toggleId);
      const top = rows.slice(0, limit);
      const rest = rows.slice(limit);
      const tbody1 = h('tbody', {}, ...top.map(r =>
        h('tr', {}, h('td', { className: 'page-path' }, r[col1Key] || '(direct)'), h('td', { className: 'views-num', style: { textAlign: 'right' } }, String(r[col2Key])))
      ));
      const tbody2 = rest.length ? h('tbody', { className: 'hidden-rows', id }, ...rest.map(r =>
        h('tr', {}, h('td', { className: 'page-path' }, r[col1Key] || '(direct)'), h('td', { className: 'views-num', style: { textAlign: 'right' } }, String(r[col2Key])))
      )) : null;
      const table = h('table', { className: 'table' },
        h('thead', {}, h('tr', {}, h('th', {}, col1), h('th', { style: { textAlign: 'right' } }, col2))),
        tbody1, tbody2
      );
      const wrap = h('div', {}, h('div', { className: 'table-wrap' }, table));
      if (rest.length) {
        const btn = h('button', { className: 'toggle-btn', onclick: () => {
          const el = document.getElementById(id);
          el.classList.toggle('show');
          btn.textContent = el.classList.contains('show') ? 'Show less' : `Show ${rest.length} more`;
        } }, `Show ${rest.length} more`);
        wrap.appendChild(btn);
      }
      return wrap;
    }

