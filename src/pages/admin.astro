    // ── LEADS ──
    let leadFilter = 'new';
    let leadPage = 1;
    const LEADS_PER_PAGE = 9;

    function formatSource(guide) {
      if (!guide) return 'Unknown';
      if (guide.startsWith('vip-')) return 'VIP: ' + guide.replace('vip-', '').replace(/-/g, ' ');
      const labels = { buyers: "Buyer's Guide", sellers: "Seller's Guide", relocation: 'Relocation Guide', contact: 'Contact Form' };
      return labels[guide] || guide;
    }

    async function loadLeads() {
      const el = document.getElementById('view-leads');
      el.innerHTML = '<div class="loading">Loading leads...</div>';
      const data = await api('/leads');
      el.innerHTML = '';
      if (!data.leads?.length) { el.innerHTML = '<div class="empty">No leads yet</div>'; return; }

      const allLeads = data.leads;
      const newLeads = allLeads.filter(l => l.status === 'new');
      const openLeads = allLeads.filter(l => l.status !== 'new' && l.status !== 'trashed');

      // Sub tabs
      const tabs = h('div', { className: 'sub-tabs' },
        h('div', { className: `sub-tab ${leadFilter === 'new' ? 'active' : ''}`, onclick: () => { leadFilter = 'new'; leadPage = 1; loadLeads(); } }, `New (${newLeads.length})`),
        h('div', { className: `sub-tab ${leadFilter === 'open' ? 'active' : ''}`, onclick: () => { leadFilter = 'open'; leadPage = 1; loadLeads(); } }, `Open (${openLeads.length})`),
        h('div', { className: `sub-tab ${leadFilter === 'all' ? 'active' : ''}`, onclick: () => { leadFilter = 'all'; leadPage = 1; loadLeads(); } }, `All (${allLeads.length})`),
      );
      el.appendChild(tabs);

      const filtered = leadFilter === 'new' ? newLeads : leadFilter === 'open' ? openLeads : allLeads;

      if (!filtered.length) {
        el.appendChild(h('div', { className: 'empty' }, leadFilter === 'new' ? 'No new leads' : 'No open leads'));
        return;
      }

      const totalPages = Math.ceil(filtered.length / LEADS_PER_PAGE);
      if (leadPage > totalPages) leadPage = totalPages;
      const start = (leadPage - 1) * LEADS_PER_PAGE;
      const paged = filtered.slice(start, start + LEADS_PER_PAGE);

      const grid = h('div', { style: { display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '12px' } });
      el.appendChild(grid);

      paged.forEach(lead => {
        const card = h('div', { className: 'lead-card' },
          h('div', { className: 'lead-top' },
            h('div', {},
              h('div', { className: 'lead-name' }, lead.name || '(no name)'),
              h('a', { className: 'lead-email', href: 'mailto:' + lead.email }, lead.email),
              lead.phone ? h('div', { style: { marginTop: '4px' } }, h('a', { href: 'tel:' + lead.phone, style: { fontSize: '13px', color: 'var(--text)' } }, lead.phone)) : null,
              h('div', { className: 'lead-meta' },
                h('span', { className: 'lead-source' }, formatSource(lead.guide)),
                h('span', {}, fmtDate(lead.created_at)),
              ),
            ),
            h('span', { className: `badge badge-${lead.status || 'new'}` }, lead.status || 'new'),
          ),
          lead.notes ? h('div', { className: 'lead-notes' }, h('p', {}, lead.notes)) : null,
          h('div', { className: 'lead-actions' },
            lead.status === 'new' ? h('button', { className: 'btn btn-gold', onclick: () => updateLead(lead.id, 'contacted') }, 'Mark Contacted') : null,
            lead.status === 'contacted' ? h('button', { className: 'btn btn-gold', onclick: () => updateLead(lead.id, 'qualified') }, 'Qualified') : null,
            lead.status !== 'closed' && lead.status !== 'new' ? h('button', { className: 'btn', onclick: () => updateLead(lead.id, 'closed') }, 'Closed') : null,
            h('button', { className: 'btn btn-danger', onclick: () => updateLead(lead.id, 'trashed') }, 'Trash'),
          ),
        );
        grid.appendChild(card);
      });

      // Pagination
      if (totalPages > 1) {
        const pag = h('div', { className: 'pagination' },
          h('div', { className: `page-btn ${leadPage === 1 ? 'disabled' : ''}`, onclick: () => { leadPage--; loadLeads(); } }, '<'),
          ...Array.from({ length: totalPages }, (_, i) =>
            h('div', { className: `page-btn ${leadPage === i + 1 ? 'active' : ''}`, onclick: () => { leadPage = i + 1; loadLeads(); } }, String(i + 1))
          ),
          h('div', { className: `page-btn ${leadPage === totalPages ? 'disabled' : ''}`, onclick: () => { leadPage++; loadLeads(); } }, '>'),
        );
        el.appendChild(pag);
      }
    }

    async function updateLead(id, status) {
