---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contact Glen Robison | New Braunfels REALTOR" description="Get in touch with Glen Robison for buying, selling, or relocating to New Braunfels and the Texas Hill Country.">
  <PageHero eyebrow="Contact" title="Get in Touch." image="/images/hero-contact.png" intro="Call, text, or send a note. Glen will get back to you the same day." />

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <h2 class="mb-6">Direct Contact</h2>
        <ul class="space-y-4 text-muted">
          <li><span class="text-dim text-xs uppercase tracking-wider block mb-1">Phone</span><a href="tel:+18307307677" class="text-gold-bright text-lg">(830) 730-7677</a></li>
          <li><span class="text-dim text-xs uppercase tracking-wider block mb-1">Email</span><a href="mailto:glenrobison@gmail.com" class="text-gold-bright text-lg">glenrobison@gmail.com</a></li>
          <li><span class="text-dim text-xs uppercase tracking-wider block mb-1">Brokerage</span><span class="text-cream">Popby Realty™</span></li>
          <li><span class="text-dim text-xs uppercase tracking-wider block mb-1">Office</span><span class="text-cream">323 Arendes Dr<br />New Braunfels, TX 78132</span></li>
          <li><span class="text-dim text-xs uppercase tracking-wider block mb-1">License</span><span class="text-cream">TX #0676313</span></li>
        </ul>
      </div>
      <div>
        <h2 class="mb-6">Send a Message</h2>
        <form class="space-y-4">
          <input type="text" placeholder="Name" class="w-full bg-card border border-subtle px-4 py-3 text-text focus:border-[var(--color-gold)] outline-none" />
          <input type="email" placeholder="Email" class="w-full bg-card border border-subtle px-4 py-3 text-text focus:border-[var(--color-gold)] outline-none" />
          <input type="tel" placeholder="Phone (optional)" class="w-full bg-card border border-subtle px-4 py-3 text-text focus:border-[var(--color-gold)] outline-none" />
          <textarea placeholder="How can Glen help?" rows="5" class="w-full bg-card border border-subtle px-4 py-3 text-text focus:border-[var(--color-gold)] outline-none"></textarea>
          <button type="submit" class="btn-gold w-full">Send Message</button>
        </form>
        <p id="form-status" class="text-dim text-xs mt-3 hidden"></p>
      </div>
    </div>
  </section>
</Layout>
